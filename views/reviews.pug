extends layout

block content
  h1 Reviews for this Ride
  each review in reviews
    div.review-card
      p ⭐ #{review.rating} - #{review.review}

  form(action="/reviews/create" method="POST")
    div.form-group
      label(for="rating") Rating:
      select(name="rating" required)
        option(value="1") 1 ⭐
        option(value="2") 2 ⭐
        option(value="3") 3 ⭐
        option(value="4") 4 ⭐
        option(value="5") 5 ⭐

    div.form-group
      label(for="review") Your Review:
      textarea(name="review" required)

    button.btn.btn-primary(type="submit") Submit Review
  a.btn.btn-secondary(href="/rides") Back to Rides
